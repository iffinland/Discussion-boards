# Enable publish to Qortal from the app (requires qortalRequest in Q-App context)
# Default behavior in code is enabled unless explicitly set to false.
VITE_ENABLE_QORTAL_PUBLISH=true

# QDN name that will publish forum snapshot JSON
# Optional: if empty, app uses authenticated Qortal name automatically
VITE_QORTAL_QDN_NAME=

# Optional node URL for direct QDN/resource reads
# If empty, app uses current origin (Q-App context)
VITE_QORTAL_NODE_URL=

# Optional QDN publish metadata
VITE_QORTAL_QDN_SERVICE=DOCUMENT
VITE_QORTAL_QDN_IDENTIFIER=discussion-boards-beta
VITE_QORTAL_QDN_FILENAME=forum-state.json

# Comma-separated Qortal names that are treated as Admin
VITE_FORUM_ADMIN_NAMES=

# Optional read source URL for remote snapshot hydration
# Example: https://your-node.example/arbitrary/.../forum-state.json
VITE_QORTAL_SNAPSHOT_URL=
